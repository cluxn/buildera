# Application
APP_NAME=Buildera
APP_ENV=local
APP_KEY=base64:your-generated-key-here   # Run: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=buildera
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# Queue
QUEUE_CONNECTION=database

# API Security
APP_API_KEY=your-api-key-here            # Used by Next.js on POST /api/leads. Choose any random string (min 32 chars).

# ISR Revalidation
NEXTJS_REVALIDATE_URL=http://localhost:3000/api/revalidate   # URL of Next.js revalidation endpoint
NEXTJS_REVALIDATE_SECRET=your-revalidate-secret              # HMAC secret — must match NEXTJS_REVALIDATE_SECRET in frontend .env

# Email (Resend)
RESEND_API_KEY=re_your-resend-api-key    # From resend.com Dashboard → API Keys
RESEND_FROM_ADDRESS=noreply@buildera.co  # Verified sender domain in Resend

# Frontend CORS
FRONTEND_URL=http://localhost:3000       # Production: https://buildera.co

# n8n Webhooks (fired as queued jobs on lead/newsletter submission)
N8N_LEAD_WEBHOOK_URL=https://your-n8n-instance/webhook/lead-form-webhook-id
N8N_NEWSLETTER_WEBHOOK_URL=https://your-n8n-instance/webhook/newsletter-webhook-id
